<% layout('layouts/boilerplate') %>

    <body>
        <div class="row mt-3">
            <div class="col-8 offset-1">
                <h2>
                    <%= listing.title %>
                </h2>
            </div>
            <div class="card col-10 offset-1 show-card listing-card">
                <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing-img">
                <div class="card-body">
                    <p class="card-text">
                        Hosted By
                        <i>
                            <%= listing.owner.username %>
                        </i>
                    </p>
                    <p class="card-text">
                        <%= listing.description %>
                    </p>
                    <p class="card-text">
                        &#8377;<%= listing.price.toLocaleString("en-IN") %>
                    </p>
                    <p class="card-text">
                        <%= listing.location %>
                    </p>
                    <p class="card-text">
                        <%= listing.country %>
                    </p>
                </div>
            </div>

            <% if (currentUser && currentUser._id.equals(listing.owner._id)) { %>
                <div class="btns mb-5">
                    <form action="/listings" method="get" style="display: inline;">
                        <button class="btn btn-dark col-1 offset-3 back-btn">Back</button>
                    </form>
                    <form action="/listings/<%= listing._id%>/edit" method="get" style="display: inline;">
                        <button class="btn btn-dark col-1 offset-1 edit-btn">Edit</button>
                    </form>
                    <form action="/listings/<%= listing._id %>?_method=DELETE" method="post" style="display: inline;">
                        <button class="btn btn-dark col-1 offset-1 del-btn">Delete</button>
                    </form>
                </div>
                <% } else { %>
                    <div class="btns mb-5">
                        <form action="/listings" method="get" style="display: inline;">
                            <button class="btn btn-dark col-1 offset-3 back-btn">Back</button>
                        </form>
                    </div>
                    <% } %>

                        <br><br>

                        <div class="col-8 offset-2 mb-3">
                            <hr>
                            <% if(currentUser) { %>
                                <h4>Leave a Review</h4>
                                <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate
                                    class="needs-validation">
                                    <div class="mb-3 mt-3">
                                        <label for="rating" class="form-label">Rating: </label>
                                        <fieldset class="starability-slot">
                                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]"
                                                value="1" checked aria-label="No rating." />
                                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                            <label for="first-rate1" title="Terrible">1 star</label>
                                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                            <label for="first-rate2" title="Not good">2 stars</label>
                                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                            <label for="first-rate3" title="Average">3 stars</label>
                                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                            <label for="first-rate4" title="Very good">4 stars</label>
                                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                            <label for="first-rate5" title="Amazing">5 stars</label>
                                        </fieldset>
                                    </div>

                                    <div class="mb-3 mt-3">
                                        <label for="comment" class="form-label">Comments: </label>
                                        <textarea name="review[comment]" id="comment" cols="30" rows="5"
                                            class="form-control" required></textarea>
                                        <div class="invalid-feedback">Comment should not be empty!</div>
                                        <div class="valid-feedback">Valid Comment!</div>
                                    </div>

                                    <button type="submit" class="btn btn-primary">Submit</button>
                                </form>
                                <hr>
                                <% } %>

                                    <div class="row">
                                        <h4>Reviews</h4>
                                        <% if (listing.reviews.length> 0) { %>
                                            <% for (let review of listing.reviews) { %>
                                                <div class="card mb-3 ms-3 col-5">
                                                    <div class="card-body mt-3">
                                                        <h5 class="card-title">@<%= review.author.username %>
                                                        </h5>
                                                        <div class="starability-result card-text"
                                                            data-rating="<%= review.rating %>"></div>
                                                        <p class="card-text">
                                                            <%= review.comment %>
                                                        </p>
                                                        <form
                                                            action="/listings/<%= listing._id %>/reviews/<%=review._id %>?_method=DELETE"
                                                            method="post" class="mb-3 mt-3">
                                                            <button class="btn btn-sm btn-dark">Delete</button>
                                                        </form>
                                                    </div>
                                                </div>
                                                <% } %>
                                                    <% } else { %>
                                                        <p>No reviews yet.</p>
                                                        <% } %>
                                    </div>
                        </div>
                        <div class="col-8 offset-2 mb-3" style="height: 400px;">
                            <h3>Where you'll be</h3>
                            <div id="map">Map feature Coming Soon</div>
                        </div>
        </div>
    </body>

